# ── Database ──────────────────────────────────────────────
# Supabase: Settings → Database → Connection string (URI)
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DB
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/dalkkak

# ── Cache & Queue ─────────────────────────────────────────
# Upstash: Dashboard → Redis → REST URL
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-64-char-string

# ── AI ────────────────────────────────────────────────────
# Anthropic Console → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── External Services ─────────────────────────────────────
# GitHub → Settings → Developer Settings → Personal Access Tokens
GITHUB_TOKEN=ghp_...

# Railway → Account Settings → Tokens
RAILWAY_API_KEY=...

# Stripe → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend → API Keys
RESEND_API_KEY=re_...

# ── Storage ───────────────────────────────────────────────
# Cloudflare R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=dalkkak-generated

# ── App ───────────────────────────────────────────────────
PORT=8000
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000
